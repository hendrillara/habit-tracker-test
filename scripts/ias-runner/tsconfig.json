{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": ["node"],
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["run.mjs", "src/**/*.mjs", "lib/**/*.mjs", "commands/**/*.mjs"]
}

